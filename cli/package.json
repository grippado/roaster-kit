    "postpack": "node scripts/postpack.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "openai": "^4.104.0"
  },
  "publishConfig": {
